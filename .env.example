# Painel Financeiro — Healthycann
# Copie este arquivo para .env e preencha. Sem .env, o painel abre com dados
# de exemplo embutidos.

# Porta do servidor (padrão 3001)
PORT=3001

# ------------------------------------------------------------------
# Fonte de dados (provider de ERP)
# ------------------------------------------------------------------
# Qual provider usar:
#   mock → dados de exemplo (vê o painel "ao vivo" sem o ERP real)
#   d9   → ERP real da D9 (precisa das credenciais abaixo)
# Em branco: usa o ERP D9 se estiver configurado; senão, dados de exemplo.
ERP_PROVIDER=

# Credenciais da D9Pro API (autenticação via header "token")
# Doc/spec da instância: https://healthycann.d9pro.com/api/api.yaml
D9_API_URL=https://healthycann.d9pro.com/api
D9_API_TOKEN=

# (opcional) IDs de status que contam como "recebido" (pago/entregue), ex.: 8,16
# Sem isto, o painel deduz pelo nome do status (pago/entregue/concluído...).
D9_STATUS_RECEBIDOS=

# (opcional) IDs de status de "em trânsito" (aba Resumo), ex.: 20
# Sem isto, deduz pelo nome (em trânsito/enviado/despachado...).
D9_STATUS_TRANSITO=

# (opcional) Qual relatório CSV conta como "Clientes" na aba Resumo:
# patients | associates | patientsWithClient (padrão patients)
D9_EXPORT_CLIENTES=patients

# (opcional) Meta de faturamento por mês (padrão da aba Vendas). Também dá para
# editar direto no painel (fica salvo no navegador). Ex.: 400000
D9_META_MENSAL=

# ------------------------------------------------------------------
# Login do painel (proteção por senha)
# ------------------------------------------------------------------
# Defina os DOIS para exigir usuário/senha ao abrir o painel.
# Em branco = painel aberto (uso local). Online, SEMPRE defina.
PAINEL_USUARIO=
PAINEL_SENHA=
